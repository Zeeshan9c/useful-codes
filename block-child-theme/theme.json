  "styles": {
    "spacing": {
      "blockGap": "0",
      "padding": {
        "right": "16px",
        "left": "16px"
      }
    },

    "custom": {
      "shadows": {
        "mega-menu": "0px 4px 40px 0px #0000000A"
      },
      "spacing": {
        "small": "max(1.25rem, 2vw)",
        "medium": "max(2rem, 4vw)",
        "large": "max(3rem, 6vw)"
      }
    },

    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--primary)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--source-sans-3)",
      "fontSize": "var(--wp--preset--font-size--body-body)",
      "fontWeight": "400",
      "lineHeight": "1.2"
    },

    "elements": {
      "body": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--body)",
          "fontWeight": "400",
          "lineHeight": "1.4",
          "fontFamily": "var(--wp--preset--font-family--source-sans-3)",
          "letterSpacing": "normal"
        },
        "color": {
          "text": "var(--wp--preset--color--dark-navy)"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--accent)" },
        "typography": { "textDecoration": "underline" }
      },

      "link": {
        "color": { "text": "var(--wp--preset--color--accent)" },
        "typography": { "textDecoration": "underline" },
        ":focus": {
          "outline": {
            "color": "transparent",
            "style": "none",
            "width": "0px",
            "offset": "0px"
          }
        },
        ":focus-visible": {
          "outline": {
            "color": "transparent",
            "style": "none",
            "width": "0px",
            "offset": "0px"
          }
        }
      },

      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--libre-baskerville)",
          "fontSize": "var(--wp--preset--font-size--display-lg)",
          "fontWeight": "700",
          "lineHeight": "1",
          "letterSpacing": "0"
        }
      },

      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--libre-baskerville)",
          "fontSize": "var(--wp--preset--font-size--heading-md)",
          "fontWeight": "400",
          "lineHeight": "1.2",
          "letterSpacing": "0"
        }
      },

      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--libre-baskerville)",
          "fontSize": "var(--wp--preset--font-size--title)",
          "fontWeight": "700",
          "lineHeight": "1.2",
          "letterSpacing": "0"
        }
      },

      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--source-sans-3)",
          "fontSize": "var(--wp--preset--font-size--heading-sm)",
          "fontWeight": "400",
          "lineHeight": "1.2",
          "letterSpacing": "0"
        }
      },

      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--libre-baskerville)",
          "fontSize": "var(--wp--preset--font-size--heading-xs)",
          "fontWeight": "400",
          "lineHeight": "1",
          "letterSpacing": "0"
        }
      },

      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--source-sans-3)",
          "fontSize": "var(--wp--preset--font-size--caption)",
          "fontWeight": "700",
          "lineHeight": "1.2",
          "letterSpacing": "0"
        }
      },

      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "color": "var(--wp--preset--color--accent)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--white)",
            "text": "var(--wp--preset--color--accent)"
          },
          "border": {
            "color": "var(--wp--preset--color--accent)"
          }
        }
      }
    },

    "blocks": {
      "core/button": {
        "spacing": {
          "padding": {
            "top": "23px",
            "bottom": "21px",
            "left": "30.5px",
            "right": "30px"
          }
        },
        "border": {
          "radius": "8px",
          "style": "solid",
          "width": "2px"
        },
        "typography": {
          "fontSize": "clamp(18px, 1vw , 18px)",
          "fontWeight": "700",
          "letterSpacing": "0",
          "textTransform": "unset",
          "lineHeight": "1"
        },
        "variations": {
          "outline": {
            "spacing": {
              "padding": {
                "top": "23px",
                "bottom": "21px",
                "left": "30.5px",
                "right": "30px"
              }
            },
            "border": {
              "radius": "8px",
              "style": "solid",
              "width": "2px"
            },
            "typography": {
              "fontSize": "clamp(18px, 1vw , 18px)",
              "fontWeight": "700",
              "letterSpacing": "0",
              "textTransform": "unset",
              "lineHeight": "1"
            }
          }
        }
      },

      "core/post-comments-form": {
        "elements": {
          "p": {
            "typography": {
              "fontSize": "var(--wp--preset--font-size--body-body)",
              "fontWeight": "400",
              "lineHeight": "1.2"
            },
            "color": {
              "text": "var(--wp--preset--color--slate)"
            }
          }
        }
      },

      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--body-body)",
          "fontWeight": "500",
          "letterSpacing": "0.02em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },

      "core/navigation-link": {
        "spacing": {
          "padding": {
            "top": "12px",
            "bottom": "12px",
            "left": "24px",
            "right": "24px"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--body-body)",
          "fontWeight": "500",
          "letterSpacing": "0.02em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "elements": {
          "link": {
            ":hover": {
              "color": {
                "text": "var(--wp--preset--color--accent)"
              }
            }
          }
        }
      },

      "core/image": {
        "filter": {
          "contrast": "105%",
          "brightness": "102%",
          "saturate": "110%"
        },
        "border": {
          "radius": "12px"
        },
        "spacing": {
          "margin": {
            "top": "var(--wp--preset--spacing--medium)",
            "bottom": "var(--wp--preset--spacing--medium)"
          }
        }
